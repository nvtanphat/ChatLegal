MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=vn_law_chatbot
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=300
EMBEDDING_MODEL=huyydangg/DEk21_hcmute_embedding
EMBEDDING_USE_VI_TOKENIZER=true
EMBEDDING_FALLBACK_MODELS=intfloat/multilingual-e5-small,sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_CACHE_DIR=data/model_cache
RERANKER_MODEL=AITeamVN/Vietnamese_Reranker
RERANKER_CACHE_DIR=data/model_cache
CHROMA_DIR=data/vectordb/chroma
TOP_K_RETRIEVAL=8
USE_QA_COLLECTION=true
QA_COLLECTION_NAME=qa_collection
TOP_K_DENSE_QA=4
TOP_K_RERANK=4
TOP_K_RERANK_POOL=6
HF_TOKEN=
